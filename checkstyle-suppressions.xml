<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!--
        Checkstyle suppressions for java-commons platform
        Suppress less critical checks in specific contexts
    -->

    <!-- Test classes: Spotless (GJF) already enforces formatting.
         Suppress style/javadoc checks that add friction without value in tests. -->
    <suppress checks="MissingJavadocType|MissingJavadocMethod" files=".*Test\.java"/>
    <suppress checks="MissingJavadocType|MissingJavadocMethod" files=".*/src/test/.*"/>
    <!-- Suppress remaining google_checks.xml rules for test sources:
         Javadoc content/style, import ordering, magic numbers, design checks -->
    <suppress checks="Javadoc.*|SummaryJavadoc|JavadocParagraph|JavadocStyle|JavadocTagContinuationIndentation|RequireEmptyLineBeforeBlockTagGroup|AtclauseOrder|NonEmptyAtclauseDescription|JavadocVariable|JavadocMethod|JavadocContentLocation|InvalidJavadocPosition|DesignForExtension|HideUtilityClassConstructor|VisibilityModifier|MagicNumber" files=".*/src/test/.*"/>

    <!-- Generated code -->
    <suppress checks="." files=".*/target/generated-sources/.*"/>

    <!-- Configuration and starter classes -->
    <suppress checks="MissingJavadocType" files=".*Configuration\.java"/>
    <suppress checks="MissingJavadocType" files=".*Properties\.java"/>

    <!-- Records and simple DTOs -->
    <suppress checks="MissingJavadocMethod" files=".*Record\.java"/>

    <!--  Main classes (examples/demos) -->
    <suppress checks="MissingJavadocType|HideUtilityClassConstructor" files=".*Main\.java"/>

    <!-- Package-info files -->
    <suppress checks="JavadocPackage" files="package-info\.java"/>

    <!-- RFC7807 is a well-known standard abbreviation; renaming breaks the public API -->
    <suppress checks="AbbreviationAsWordInName" files=".*RFC7807ProblemDetail\.java"/>
    <suppress checks="AbbreviationAsWordInName" files=".*Problems\.java"/>

    <!-- SMS/MMS are industry-standard abbreviations; renaming would break public API -->
    <suppress checks="AbbreviationAsWordInName" files=".*/ports/sms/.*\.java"/>

    <!-- ML is an industry-standard abbreviation for Machine Learning -->
    <suppress checks="AbbreviationAsWordInName" files=".*/ports/ml/.*\.java"/>

    <!-- GraphQL is a proper noun / well-known technology name -->
    <suppress checks="AbbreviationAsWordInName" files=".*/graphql/.*\.java"/>

    <!-- Full logger class name inside a <pre> Javadoc block exceeds line limit; cannot wrap -->
    <suppress checks="LineLength" files=".*RequestResponseLoggingFilter\.java"/>

    <!-- Compression adapters: nested switch expressions inside ternary or method returns
         produce indentation level mismatches that Checkstyle cannot handle correctly. -->
    <suppress checks="Indentation" files=".*CompressionFactory\.java"/>
    <suppress checks="Indentation" files=".*StreamingCompressionAdapter\.java"/>
    <suppress checks="Indentation" files=".*MultiAlgorithmCompressionAdapter\.java"/>

</suppressions>
