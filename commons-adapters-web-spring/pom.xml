<project xmlns="http://maven.apache.org/POM/4.0.0">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.marcusprado02.commons</groupId>
        <artifactId>commons-parent</artifactId>
        <version>0.1.2-SNAPSHOT</version>
        <relativePath> ../commons-parent/pom.xml</relativePath>
    </parent>

    <artifactId>commons-adapters-web-spring</artifactId>

    <dependencies>
        <dependency>
            <groupId>com.marcusprado02.commons</groupId>
            <artifactId>commons-adapters-web</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>com.marcusprado02.commons</groupId>
            <artifactId>commons-platform</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>com.marcusprado02.commons</groupId>
            <artifactId>commons-adapters-otel</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>com.marcusprado02.commons</groupId>
            <artifactId>commons-app-observability</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>com.marcusprado02.commons</groupId>
            <artifactId>commons-kernel-errors</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Spring Web (versions come from spring-boot-dependencies imported by commons-bom) -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>

    </dependencies>

    <properties>
        <jacoco.check.skip>true</jacoco.check.skip>
    </properties>

    <build>
        <plugins>
            <plugin>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <failIfNoTests>false</failIfNoTests>
                </configuration>
            </plugin>
        </plugins>
    </build>

</project>
