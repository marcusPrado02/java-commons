<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        OWASP Dependency-Check suppressions
        Each entry documents: CVE(s), reason, and review date where applicable.
    -->

    <!-- FALSE POSITIVE: commons-adapters-cache-memcached is a Java adapter wrapping
         net.spy:spymemcached. dependency-check matches the artifact name "memcached"
         against cpe:/a:memcached:memcached. All flagged CVEs (CVE-2016-8704/8705/8706,
         CVE-2017-9951, CVE-2018-1000127, CVE-2019-11596, CVE-2023-46852/46853,
         CVE-2011-4971, CVE-2013-7239/7291) target the C Memcached server binary only.
         Using packageUrl regex to match regardless of SNAPSHOT version string. -->
    <suppress>
        <notes><![CDATA[
        False positive: CPE name collision between the Java adapter module
        "commons-adapters-cache-memcached" and the C Memcached server CPE.
        All flagged CVEs affect the C server binary only; not applicable to Java code.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.marcusprado02\.commons/commons-adapters-cache-memcached@.*$</packageUrl>
        <cpe>cpe:/a:memcached:memcached</cpe>
    </suppress>

    <!-- NO FIX AVAILABLE: CVE-2026-33186 (CVSS 9.1) — unauthenticated resource exhaustion
         via malformed HTTP/2 CONTINUATION frames in gRPC. Affects versions 1.55.1, 1.59.1,
         1.75.0. Fix version grpc-java 1.75.1 not yet published on Maven Central (2026-04-19).
         Mitigation: gRPC services are internal only, not exposed to the internet.
         Review: remove once grpc-java >= 1.75.1 is available and dependency is bumped. -->
    <suppress until="2026-07-19">
        <notes><![CDATA[
        CVE-2026-33186: gRPC HTTP/2 CONTINUATION frame resource exhaustion (CVSS 9.1).
        No fix version on Maven Central as of 2026-04-19. Re-evaluate when grpc-java 1.75.1+ ships.
        ]]></notes>
        <cve>CVE-2026-33186</cve>
    </suppress>

